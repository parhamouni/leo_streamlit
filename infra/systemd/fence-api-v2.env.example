# EnvironmentFile for /etc/fence-api-v2/env (chmod 600, owner root).
# Copy to /etc/fence-api-v2/env on the AWS box and fill in the values.

# --- Auth ---
# `supabase` requires a real Supabase Bearer on every JWT-only endpoint
# and a valid X-User-Id (UUID) on legacy endpoints. `both` keeps the
# X-User-Id fallback alive — useful during cutover but tighten to
# `supabase` for production.
FENCE_API_AUTH_MODE=supabase

SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_JWKS_URL=https://<project>.supabase.co/auth/v1/.well-known/jwks.json
# If you use the legacy HS256 JWT (older Supabase projects), set:
# SUPABASE_JWT_SECRET=...

# --- Postgres (Supabase) ---
# Use the pooler URL for the FastAPI process (short-lived requests):
DATABASE_URL=postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# --- CORS ---
# Comma-separated. Must include the Vercel production domain + any
# fixed preview/staging domains. Keep localhost for ad-hoc debugging
# from your laptop against the prod backend.
FENCE_CORS_ORIGINS=https://app.<your-domain>,https://leo-fence.vercel.app,http://localhost:3000

# Optional regex applied IN ADDITION to FENCE_CORS_ORIGINS. Useful for
# Vercel preview deploys whose URLs change per branch / commit hash.
# Example below matches any leo-fence preview URL on .vercel.app:
# FENCE_CORS_ORIGIN_REGEX=^https://leo-fence-(git-.+|[a-z0-9-]+)\.vercel\.app$

# --- LLM / OCR (carry over from the legacy stack's secrets.toml) ---
OPENAI_API_KEY=sk-...
LANDINGAI_API_KEY=...
AZURE_VISION_ENDPOINT=https://<region>.cognitiveservices.azure.com/
AZURE_VISION_KEY=...
GOOGLE_CLOUD_PROJECT_ID=...
GOOGLE_APPLICATION_CREDENTIALS=/etc/fence-api-v2/google-sa.json

# --- Spend caps (carry over) ---
# MAX_DAILY_SPEND_USD=50
